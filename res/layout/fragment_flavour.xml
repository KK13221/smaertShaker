<?xml version="1.0" encoding="utf-8"?>
<!-- SCREEN 2 — Choose Your Flavour · Figma 1:223 (empty) + 1:341 (selected) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/screen_flavour"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ss_background">

    <!-- Logo chip top-right -->
    <include android:id="@+id/include_logo" layout="@layout/view_logo_chip"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Heading + subtitle -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="@dimen/ss_content_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!--
          Kotlin: SpannableString — "your flavour" (#BBF172):
            val s = SpannableString("Choose your flavour")
            s.setSpan(ForegroundColorSpan(Color.parseColor("#BBF172")), 7, 19, 0)
            tv_heading.text = s
        -->
        <TextView
            android:id="@+id/tv_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your flavour"
            android:textSize="@dimen/ss_heading_size"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/ss_text_primary"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ss_heading_gap"
            android:text="@string/flavour_subtitle"
            android:textSize="@dimen/ss_subtitle_size"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/ss_text_primary"
            android:gravity="center" />
    </LinearLayout>

    <!-- 5 flavour cards - horizontal RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_flavours"
        android:layout_width="0dp"
        android:layout_height="@dimen/ss_card_height"
        android:layout_marginTop="28dp"
        android:layout_marginStart="@dimen/ss_screen_padding_h"
        android:layout_marginEnd="@dimen/ss_screen_padding_h"
        android:overScrollMode="never"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_header"
        tools:listitem="@layout/item_flavour_card"
        tools:itemCount="5"
        tools:orientation="horizontal" />

    <!-- Bottom bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/ss_bottom_bar_height"
        android:paddingStart="@dimen/ss_screen_padding_h"
        android:paddingEnd="@dimen/ss_screen_padding_h"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Total left -->
        <LinearLayout
            android:id="@+id/ll_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textSize="@dimen/ss_total_label_size"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/ss_text_muted" />

            <TextView
                android:id="@+id/tv_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ss_total_gap"
                android:text="₹ 0"
                android:textSize="@dimen/ss_total_amount_size"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/ss_white"
                tools:text="₹ 297" />
        </LinearLayout>

        <!-- Buttons right -->
        <LinearLayout
            android:id="@+id/ll_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="@dimen/ss_btn_min_width"
                android:layout_height="@dimen/ss_btn_height"
                android:text="@string/btn_back"
                android:textColor="@color/ss_white"
                android:background="@drawable/bg_button_outline_green"
                android:stateListAnimator="@null"
                style="@style/SS.Button.Base" />

            <Space android:layout_width="@dimen/ss_btn_gap" android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btn_continue"
                android:layout_width="@dimen/ss_btn_min_width"
                android:layout_height="@dimen/ss_btn_height"
                android:text="@string/btn_continue"
                android:textColor="@color/ss_btn_inactive_text"
                android:background="@drawable/bg_button_inactive"
                android:enabled="false"
                android:stateListAnimator="@null"
                style="@style/SS.Button.Base" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
