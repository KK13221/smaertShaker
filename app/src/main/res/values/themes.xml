<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartShake" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/ss_background</item>
        <item name="android:colorBackground">@color/ss_background</item>
        <item name="colorPrimary">@color/ss_green</item>
        <item name="colorOnPrimary">@color/ss_background</item>
        <item name="colorSurface">@color/ss_surface</item>
        <item name="colorOnSurface">@color/ss_text_primary</item>
        <item name="android:textColorPrimary">@color/ss_text_primary</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowKeepScreenOn">true</item>
    </style>

    <!-- Button base -->
    <style name="SS.Button.Base" parent="Widget.MaterialComponents.Button">
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">@dimen/ss_btn_corner</item>
        <item name="elevation">0dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">@dimen/ss_btn_height</item>
        <item name="android:paddingStart">@dimen/ss_btn_padding_h</item>
        <item name="android:paddingEnd">@dimen/ss_btn_padding_h</item>
        <item name="android:minWidth">@dimen/ss_btn_min_width</item>
        <item name="android:textSize">@dimen/ss_btn_text_size</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Nutrition text -->
    <style name="SS.Text.NutritionHeader">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">@dimen/ss_nutrition_text_size</item>
        <item name="android:textColor">@color/ss_text_primary</item>
    </style>
    <style name="SS.Text.NutritionValue">
        <item name="android:fontFamily">@font/poppins_light</item>
        <item name="android:textSize">@dimen/ss_nutrition_text_size</item>
        <item name="android:textColor">@color/ss_text_primary</item>
    </style>
</resources>
